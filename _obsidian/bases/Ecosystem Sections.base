filters:
  and:
    - file.inFolder("ecosystem-section")
views:
  - name: All Ecosystem Sections
    order:
      - file.name
      - title
      - slug
      - status
    type: table
  - groupBy:
      direction: ASC
      property: status
    name: By Status
    order:
      - file.name
      - title
      - slug
      - status
    type: table
